---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  pageType?: "profile" | "article" | "webpage";
  keywords?: string[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonical = "https://jawadabbasi.com",
  pageType = "profile",
  keywords = [],
  noIndex = false,
} = Astro.props;

const siteRoot = "https://jawadabbasi.com";
const socialImage = new URL("/assets/og-cover.png", canonical).toString();
const personId = `${siteRoot}#person`;
const websiteId = `${siteRoot}#website`;
const pageEntity = pageType === "profile" ? {
  "@type": "ProfilePage",
  "@id": canonical,
  url: canonical,
  name: title,
  description,
  isPartOf: { "@id": websiteId },
  mainEntity: { "@id": personId },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: socialImage,
    width: 1200,
    height: 630,
  },
} : pageType === "article" ? {
  "@type": "TechArticle",
  "@id": `${canonical}#article`,
  url: canonical,
  headline: title,
  description,
  image: socialImage,
  author: { "@id": personId },
  publisher: { "@id": personId },
  isPartOf: { "@id": websiteId },
  mainEntityOfPage: canonical,
  keywords,
  inLanguage: "en",
} : {
  "@type": "WebPage",
  "@id": canonical,
  url: canonical,
  name: title,
  description,
  isPartOf: { "@id": websiteId },
  inLanguage: "en",
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    pageEntity,
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: canonical,
      name: "Jawad Abbasi",
      description,
      inLanguage: "en",
      publisher: { "@id": personId },
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Jawad Abbasi",
      url: canonical,
      image: socialImage,
      jobTitle: "Senior DevOps Engineer",
      email: "mailto:jawadabbasi54@gmail.com",
      telephone: "+92 332 5501123",
      sameAs: ["https://linkedin.com/in/jawad-abbasi-573772117"],
      knowsAbout: [
        "Amazon Web Services",
        "DevOps",
        "DevSecOps",
        "Terraform",
        "CI/CD",
        "Cloud infrastructure",
        "Cloud observability",
        "AWS IoT",
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#030817" />
    <meta name="description" content={description} />
    <meta name="author" content="Jawad Abbasi" />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType === "article" ? "article" : "website"} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Jawad Abbasi — Senior DevOps Engineer portfolio" />
    <meta property="og:site_name" content="Jawad Abbasi" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Jawad Abbasi — Senior DevOps Engineer portfolio" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/favicon.svg?v=20260711-3" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <noscript><style>.reveal{opacity:1!important;transform:none!important}.scene-loader{display:none!important}</style></noscript>
  </head>
  <body>
    <slot />

    <script is:inline src="/page-loader.js?v=20260714-landmask5" defer></script>
    <script is:inline src="/spider-web.js?v=20260714-adaptive2" defer></script>
  </body>
</html>
