---
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Jawad Abbasi | Senior DevOps Engineer";
const description = "Jawad Abbasi — Senior DevOps Engineer specializing in AWS, Terraform, CI/CD, DevSecOps, observability, and enterprise IoT platforms.";
---

<BaseLayout title={title} description={description}>
  <canvas class="spider-web-background" id="spider-web-background" aria-hidden="true"></canvas>
  <div class="page-noise" aria-hidden="true"></div>
  <div class="ambient ambient-one" aria-hidden="true"></div>
  <div class="ambient ambient-two" aria-hidden="true"></div>

  <SiteHeader home />

  <a class="page-scroll-rail" href="#expertise" aria-label="Scroll through the portfolio">
    <span class="page-scroll-track" aria-hidden="true"><span class="page-scroll-progress"></span></span>
    <span class="page-scroll-key" aria-hidden="true">
      <svg viewBox="0 0 24 24"><path d="M12 4v15m0 0-6-6m6 6 6-6" /></svg>
    </span>
    <small>SCROLL</small>
  </a>

  <main>
    <section class="hero section-shell" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="hero-eyebrow reveal"><span></span>I engineer reliable cloud systems</p>
        <p class="hero-name reveal">Jawad Abbasi</p>
        <p class="hero-role reveal">Senior DevOps Engineer <span>·</span> Islamabad, Pakistan</p>
        <h1 id="hero-title" class="reveal">End-to-end DevOps.<br />Built for scale.<br />Engineered for <span>reliability.</span></h1>
        <p class="hero-lead reveal">From code to cloud and beyond—secure, automated, observable delivery pipelines on AWS for enterprise-scale cloud and IoT platforms.</p>
        <div class="hero-actions reveal">
          <a class="button button-primary" href="#work">Explore my work <span>→</span></a>
          <!--email_off--><a class="button button-secondary" href="mailto:jawadabbasi54@gmail.com">Start a conversation</a><!--/email_off-->
          <a class="hero-resume-link" href="/Jawad_Abbasi_Resume.pdf" download>Download résumé ↓</a>
        </div>
        <div class="hero-stats reveal" aria-label="Professional highlights">
          <article><strong>7</strong><span>Years<br />experience</span></article>
          <article><strong>4</strong><span>Cloud<br />environments</span></article>
          <article><strong>19</strong><span>GW solar<br />supported</span></article>
          <article><strong>4,600</strong><span>PV systems<br />in platform</span></article>
        </div>
        <div class="trusted reveal"><span>PRIMARY CLOUD</span><strong>aws</strong></div>
      </div>

      <div class="visual-column reveal">
        <div class="globe-stage" id="globe-stage" role="region" aria-label="Interactive rotatable DevOps lifecycle globe">
          <img class="prototype-fallback" id="prototype-fallback" data-src="/assets/prototype-fallback.png" alt="Static DevOps lifecycle command center" width="1672" height="941" />
          <canvas id="globe-canvas" aria-hidden="true"></canvas>
          <div class="glass-reflection" aria-hidden="true"></div>
          <div class="scene-loader" id="scene-loader" aria-live="polite">
            <span class="loader-ring"></span>
            <div><strong>Loading crystal DevOps globe</strong><small>Rendering glass systems network</small></div>
          </div>
          <div class="scene-error" id="scene-error" hidden>
            <strong>Interactive mode unavailable</strong>
            <span>A static command center is shown instead.</span>
          </div>
          <div class="globe-ui-layer" id="globe-ui-layer" role="group" aria-label="Animated DevSecOps delivery flow">
            <svg class="pipeline-overlay" id="pipeline-overlay" aria-hidden="true">
              <defs>
                <linearGradient id="code-gradient" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0" stop-color="#5bc6ff" />
                  <stop offset=".55" stop-color="#2f7dff" />
                  <stop offset="1" stop-color="#8a6dff" />
                </linearGradient>
                <linearGradient id="monitor-gradient" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0" stop-color="#28dbff" />
                  <stop offset="1" stop-color="#6dffcf" />
                </linearGradient>
                <linearGradient id="feedback-gradient" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0" stop-color="#ff9a2d" />
                  <stop offset=".48" stop-color="#ffd079" />
                  <stop offset="1" stop-color="#58c9ff" />
                </linearGradient>
                <marker id="arrow-code" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                  <path d="M 0 0 L 10 5 L 0 10 z" fill="#4ca8ff" />
                </marker>
                <marker id="arrow-monitor" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                  <path d="M 0 0 L 10 5 L 0 10 z" fill="#4ee9e0" />
                </marker>
                <marker id="arrow-deploy" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
                  <path d="M 0 0 L 10 5 L 0 10 z" fill="#ff9228" />
                </marker>
                <marker id="arrow-feedback" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
                  <path d="M 0 0 L 10 5 L 0 10 z" fill="#79d6ff" />
                </marker>
                <filter id="blue-glow" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1.4" result="blur" />
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <filter id="orange-glow" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1.8" result="blur" />
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <clipPath id="globe-surface-clip" clipPathUnits="userSpaceOnUse">
                  <path id="globe-surface-clip-path" d="" />
                </clipPath>
              </defs>
              <g clip-path="url(#globe-surface-clip)">
                <path id="code-path" class="flow-path flow-path-code" data-layers="code" marker-end="url(#arrow-code)" d="" />
                <path id="monitor-path" class="flow-path flow-path-monitor" data-layers="monitoring" marker-end="url(#arrow-monitor)" d="" />
                <path id="deployment-path" class="flow-path flow-path-deployment deployment-wave-path" data-layers="deployment" data-wave-index="0" marker-end="url(#arrow-deploy)" d="" />
                <path id="deployment-path-2" class="flow-path flow-path-deployment deployment-wave-path" data-layers="deployment" data-wave-index="1" marker-end="url(#arrow-deploy)" d="" />
                <path id="deployment-path-3" class="flow-path flow-path-deployment deployment-wave-path" data-layers="deployment" data-wave-index="2" marker-end="url(#arrow-deploy)" d="" />
                <path id="feedback-path" class="flow-path flow-path-feedback" data-layers="monitoring" marker-end="url(#arrow-feedback)" d="" />
              </g>
            </svg>

            <div class="devops-node developer-node" data-node="developer" data-layers="code monitoring" aria-label="Developer writing, responding to alerts and pushing improvements">
              <button class="node-orb node-orb-developer" type="button" title="Developer">
                <svg viewBox="0 0 64 64" aria-hidden="true">
                  <path d="M22 18 8 32l14 14M42 18l14 14-14 14M37 11 27 53" fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="typing-console" id="typing-console" aria-hidden="true">
                <div class="typing-console-bar"><i></i><i></i><i></i></div>
                <pre id="typing-code"></pre><span class="typing-caret"></span>
              </div>
              <div class="component-caption"><strong>Developer</strong><span>Code & improve</span></div>
              <div class="component-tooltip" role="tooltip">Writes code, receives production alerts, investigates the signal, and pushes the next improvement.</div>
            </div>

            <div class="devops-node git-node" data-node="git" data-layers="code" aria-label="Git repository">
              <div class="icon-cluster icon-cluster-git" tabindex="0" role="group" aria-label="Bitbucket, GitHub and GitLab repositories">
                <span class="brand-orb-icon" title="Bitbucket"><img src="/assets/icons/bitbucket.svg" alt="" width="128" height="128" /></span>
                <span class="brand-orb-icon" title="GitHub"><img src="/assets/icons/github.svg" alt="" width="128" height="128" /></span>
                <span class="brand-orb-icon" title="GitLab"><img src="/assets/icons/gitlab.svg" alt="" width="128" height="128" /></span>
              </div>
              <div class="component-caption"><strong>Repository</strong><span>Version control</span></div>
              <div class="component-tooltip" role="tooltip">Bitbucket, GitHub, and GitLab preserve source history and trigger automated delivery workflows.</div>
            </div>

            <div class="devops-node pipeline-node" data-node="cicd" data-layers="code" aria-label="DevSecOps CI/CD pipeline">
              <div class="pipeline-stage-icons" tabindex="0" role="group" aria-label="Security, build, test and deployment pipeline">
                <span class="pipeline-stage" data-stage="security" title="Snyk security scan"><img src="/assets/icons/snyk.svg" alt="" width="24" height="24" /></span>
                <span class="pipeline-stage" data-stage="build" title="Jenkins build"><img src="/assets/icons/jenkins.svg" alt="" width="128" height="128" /></span>
                <span class="pipeline-stage" data-stage="test" title="Playwright tests"><img src="/assets/icons/playwright.svg" alt="" width="128" height="128" /></span>
                <span class="pipeline-stage pipeline-stage-deploy" data-stage="deploy" title="Deploy to AWS"><img src="/assets/icons/aws.svg" alt="" width="128" height="128" /></span>
              </div>
              <div class="component-caption"><strong>CI/CD</strong><span>Secure build & test</span></div>
              <div class="component-tooltip" role="tooltip">Snyk validates security, Jenkins builds, Playwright tests, and the approved application version is deployed.</div>
            </div>

            <div class="devops-node aws-node" data-node="aws" data-layers="code deployment monitoring" aria-label="AWS cloud deployment">
              <button class="node-orb node-orb-aws" type="button" title="AWS Cloud"><img src="/assets/icons/aws.svg" alt="" width="128" height="128" /></button>
              <div class="component-caption component-caption-aws"><strong>AWS Cloud</strong><span>Multi-region delivery</span></div>
              <div class="component-tooltip" role="tooltip">The approved release reaches AWS services and fans out to resilient regional and Multi-AZ destinations.</div>
            </div>

            <div class="devops-node cloudwatch-node" data-node="cloudwatch" data-layers="monitoring" aria-label="CloudWatch observability">
              <button class="node-orb node-orb-cloudwatch" type="button" title="CloudWatch monitoring">
                <svg viewBox="0 0 64 64" aria-hidden="true">
                  <path d="M10 48V26M22 48V18M34 48V31M46 48V12M8 51h45" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                  <path d="m11 33 11-8 12 9 13-15" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="component-caption"><strong>CloudWatch</strong><span>Logs & metrics</span></div>
              <div class="component-tooltip" role="tooltip">CloudWatch observes application logs, resource metrics, health signals, dashboards, and alarms.</div>
            </div>

            <div class="devops-node alerts-node" data-node="alerts" data-layers="monitoring" aria-label="Slack, phone and email notifications">
              <div class="icon-cluster icon-cluster-alerts" tabindex="0" role="group" aria-label="Slack, phone and email alerts">
                <span class="brand-orb-icon alert-slack" title="Slack"><img src="/assets/icons/slack.svg" alt="" width="128" height="128" /></span>
                <span class="brand-orb-icon alert-phone" title="Phone">
                  <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M20 8c4-2 8 11 9 15 1 3-5 5-7 7 4 8 8 12 16 16 2-2 4-8 7-7 4 1 17 5 15 9-3 7-8 10-15 8C26 51 13 38 8 19 6 12 13 7 20 8Z" fill="currentColor"/></svg>
                </span>
                <span class="brand-orb-icon alert-email" title="Email">
                  <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M8 15h48v34H8z" fill="none" stroke="currentColor" stroke-width="4" rx="4"/><path d="m10 18 22 17 22-17" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/></svg>
                </span>
              </div>
              <div class="component-caption"><strong>Alerts</strong><span>Incident response</span></div>
              <div class="component-tooltip" role="tooltip">Alarms notify Slack, phone, and email, then return actionable feedback to the developer.</div>
            </div>

            <div class="region-overlay-layer" id="region-overlay-layer" role="group" data-layers="deployment" aria-label="AWS deployment regions"></div>

            <div class="deployment-wave-pulse" id="deployment-wave-pulse" data-layers="deployment" aria-hidden="true"></div>

            <div class="application-version" id="application-version" data-layers="code" aria-hidden="true">
              <svg viewBox="0 0 64 64"><path d="m32 5 22 12v28L32 58 10 45V17Z" fill="none" stroke="currentColor" stroke-width="4"/><path d="m10 17 22 13 22-13M32 30v28" fill="none" stroke="currentColor" stroke-width="4"/></svg>
              <span>v2.4.1</span>
            </div>

            <div class="telemetry-pulse" id="telemetry-pulse" data-layers="monitoring" aria-hidden="true"></div>
            <div class="incident-notification" id="incident-notification" data-layers="monitoring" aria-hidden="true">
              <svg viewBox="0 0 64 64"><path d="M18 43h28l-4-6V26c0-7-4-12-10-13-6 1-10 6-10 13v11l-4 6Z" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/><path d="M27 49c1 5 9 5 10 0" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/><circle cx="47" cy="16" r="7" fill="#ff9228"/></svg>
            </div>
          </div>

          <div class="globe-controls">
            <button type="button" id="auto-rotate" aria-pressed="true"><span>◌</span> Auto rotate</button>
            <p><span>☝</span> Drag to rotate · Scroll to zoom</p>
          </div>
          <div class="flow-layer-controls" role="group" aria-label="Isolate DevOps flow layer">
            <button type="button" data-flow-layer="code" aria-pressed="true" title="Show only developer, repository, CI/CD and application version flow"><i class="control-swatch control-swatch-code"></i><span>Code flow</span></button>
            <button type="button" data-flow-layer="deployment" aria-pressed="true" title="Show only AWS regional deployment flow"><i class="control-swatch control-swatch-deployment"></i><span>Deployment</span></button>
            <button type="button" data-flow-layer="monitoring" aria-pressed="true" title="Show only CloudWatch, alerts and developer feedback"><i class="control-swatch control-swatch-monitoring"></i><span>Monitoring</span></button>
          </div>
        </div>
      </div>
    </section>

    <section class="expertise section-shell section-block" id="expertise">
      <div class="section-heading reveal"><p>CORE EXPERTISE</p><h2>Cloud systems designed to be secure, repeatable, and observable.</h2></div>
      <div class="expertise-grid">
        <article class="glass-card reveal"><span>01</span><h3>AWS architecture</h3><p>Multi-environment infrastructure across compute, networking, databases, serverless, security, observability, and IoT services.</p></article>
        <article class="glass-card reveal"><span>02</span><h3>Infrastructure as Code</h3><p>Terraform workflows that plan, validate, review, and provision version-controlled AWS architecture automatically.</p></article>
        <article class="glass-card reveal"><span>03</span><h3>DevSecOps delivery</h3><p>Bitbucket Pipelines and Jenkins workflows with secure OIDC access, build automation, testing, security checks, and controlled releases.</p></article>
        <article class="glass-card reveal"><span>04</span><h3>Production operations</h3><p>CloudWatch dashboards, alarms, incident response, Slack notifications, RCA, cost awareness, and reliability improvements.</p></article>
      </div>
    </section>

    <section class="work section-shell section-block" id="work">
      <div class="section-heading reveal"><p>SELECTED WORK</p><h2>TerraSmart renewable-energy IoT platform.</h2></div>
      <article class="case-study glass-panel reveal">
        <div class="case-copy"><span class="case-label">USA · ENTERPRISE IOT · SOLAR</span><h3>Operating cloud infrastructure for a large-scale solar technology platform.</h3><p>Designed and managed AWS infrastructure supporting React applications, Node.js services, Elastic Beanstalk, Lambda telemetry processing, Aurora PostgreSQL, AWS IoT Core, and multi-environment delivery workflows.</p><div class="case-points"><span>Terraform IaC</span><span>Bitbucket CI/CD</span><span>AWS IoT</span><span>CloudWatch</span><span>DevSecOps</span><span>Production support</span></div></div>
        <div class="case-metrics"><div><strong>19 GW</strong><span>solar supported</span></div><div><strong>4,600+</strong><span>PV systems</span></div><div><strong>4</strong><span>delivery environments</span></div><div><strong>24/7</strong><span>operational focus</span></div></div>
      </article>
      <div class="study-grid">
        <CaseStudyCard href="/case-studies/aws-enterprise-iot-platform" number="01" label="AWS + IOT" title="Enterprise renewable-energy cloud platform" description="Multi-environment AWS architecture connecting web applications, telemetry processing, managed data, and production operations." tags={["AWS", "IoT Core", "Lambda", "Aurora"]} />
        <CaseStudyCard href="/case-studies/terraform-multi-environment-infrastructure" number="02" label="INFRASTRUCTURE AS CODE" title="Repeatable Terraform environments" description="Reviewed infrastructure workflows for consistent Development, QA, Staging, and Production cloud foundations." tags={["Terraform", "IaC", "IAM", "Networking"]} />
        <CaseStudyCard href="/case-studies/secure-cicd-automation" number="03" label="DEVSECOPS" title="Secure CI/CD automation" description="Jenkins and Bitbucket delivery with self-hosted runners, OIDC access, security gates, containers, and AWS releases." tags={["Jenkins", "Bitbucket", "OIDC", "Snyk"]} />
        <CaseStudyCard href="/case-studies/observability-incident-response" number="04" label="RELIABILITY" title="Observability and incident response" description="CloudWatch dashboards, centralized Slack signals, production troubleshooting, RCA, and operational feedback." tags={["CloudWatch", "Slack", "RCA", "Runbooks"]} />
      </div>
    </section>

    <section class="experience experience-crystal section-shell section-block" id="experience">
      <div class="experience-ambient" aria-hidden="true"><i></i><i></i><i></i></div>
      <div class="section-heading reveal"><p>EXPERIENCE</p><h2>Seven years of cloud automation and production engineering.</h2></div>
      <div class="timeline crystal-timeline">
        <span class="timeline-progress" aria-hidden="true"></span>
        <article class="timeline-item crystal-experience-card reveal" data-experience="01">
          <div class="timeline-meta"><span class="timeline-orb"></span><time datetime="2019-01">2019 — PRESENT</time><small>07+ YEARS</small></div>
          <div class="timeline-content"><span class="experience-number">01</span><h3>Senior DevOps Engineer</h3><h4>Zigron Technologies · Client: TerraSmart</h4><p>AWS architecture, Terraform, CI/CD, cloud security, observability, AWS IoT, incident response, Linux automation, Docker, and production delivery.</p><div class="experience-tags"><span>AWS</span><span>Terraform</span><span>DevSecOps</span><span>IoT</span></div></div>
        </article>
        <article class="timeline-item crystal-experience-card reveal" data-experience="02">
          <div class="timeline-meta"><span class="timeline-orb"></span><time datetime="2018-10">2018 — 2019</time><small>FOUNDATION</small></div>
          <div class="timeline-content"><span class="experience-number">02</span><h3>DevOps Intern</h3><h4>Zigron Technologies</h4><p>Linux administration, Docker, AWS infrastructure support, deployment automation, monitoring, and CI/CD foundations.</p><div class="experience-tags"><span>Linux</span><span>Docker</span><span>CI/CD</span></div></div>
        </article>
        <article class="timeline-item crystal-experience-card reveal" data-experience="03">
          <div class="timeline-meta"><span class="timeline-orb"></span><time datetime="2017-07">2017</time><small>NETWORKS</small></div>
          <div class="timeline-content"><span class="experience-number">03</span><h3>Network Administrator Intern</h3><h4>Pakistan Television Headquarters</h4><p>LAN operations, network troubleshooting, device configuration, system administration, and infrastructure support.</p><div class="experience-tags"><span>Networking</span><span>Operations</span><span>Support</span></div></div>
        </article>
      </div>
    </section>

    <section class="about section-shell section-block" id="about">
      <div class="about-grid"><div class="section-heading reveal"><p>ABOUT</p><h2>Automation first. Security by design. Reliability as the outcome.</h2></div><div class="about-copy reveal"><p>I build systems that make delivery safer and operations calmer: clear infrastructure code, automated pipelines, least-privilege access, useful observability, and fast alerting paths.</p><p>My work spans AWS, Terraform, Git, Bitbucket, Jenkins, Docker, Linux, Bash, Python, CloudWatch, Route 53, CloudFront, API Gateway, IAM, WAF, GuardDuty, Secrets Manager, Aurora PostgreSQL, AWS Lambda, and IoT Core.</p></div></div>
    </section>

    <section class="resume section-shell section-block" id="resume">
      <div class="resume-panel glass-panel reveal">
        <div class="resume-heading"><p>RÉSUMÉ</p><h2>Seven years across cloud automation, delivery, and production operations.</h2><p>Senior DevOps Engineer based in Islamabad, Pakistan, with a BS in Computer Science and hands-on experience supporting enterprise AWS and renewable-energy IoT platforms.</p></div>
        <div class="resume-summary">
          <div><span>2019 — PRESENT</span><strong>Senior DevOps Engineer</strong><small>Zigron Technologies · TerraSmart</small></div>
          <div><span>2014 — 2018</span><strong>BS Computer Science</strong><small>Capital University of Science & Technology</small></div>
          <a class="button button-primary" href="/Jawad_Abbasi_Resume.pdf" download>Download résumé <span>↓</span></a>
        </div>
      </div>
    </section>

    <section class="contact section-shell section-block" id="contact">
      <div class="contact-panel glass-panel reveal"><div><p>LET’S BUILD RELIABLE SYSTEMS</p><h2>Need cloud infrastructure, delivery automation, or production reliability expertise?</h2></div><div class="contact-actions">
          <!--email_off--><a class="button button-primary contact-link" href="mailto:jawadabbasi54@gmail.com"><span class="contact-link-icon">@</span><span>jawadabbasi54@gmail.com</span><i>→</i></a><!--/email_off-->
          <a class="button button-secondary contact-link" href="https://linkedin.com/in/jawad-abbasi-573772117" target="_blank" rel="noopener noreferrer"><span class="contact-link-icon">in</span><span>LinkedIn profile</span><i>→</i></a>
          <a class="button button-secondary contact-link" href="tel:+923325501123"><span class="contact-link-icon">☎</span><span>+92 332 5501123</span><i>→</i></a>
        </div></div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
